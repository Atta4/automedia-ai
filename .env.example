# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_TTS_VOICE=auto
OPENAI_LLM_MODEL=gpt-4o

# ── Grok (xAI) - RECOMMENDED for real-time news ──
# Get API key from: https://console.x.ai/
GROK_API_KEY=
GROK_MODEL=grok-2-latest

# ── Google Gemini - RECOMMENDED for latest data ──
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── News API ─────────────────────────────────────
NEWSAPI_KEY=
# ── YouTube Data API ─────────────────────────────
YOUTUBE_API_KEY=
# ── Pexels ───────────────────────────────────────
PEXELS_API_KEY=
# ── Pixabay ──────────────────────────────────────
PIXABAY_API_KEY=
# ── Social Media APIs (NEW - for multi-source verification) ───────────────
# Twitter/X: Get from https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
# Reddit: Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AutoMediaAI/1.0

# Telegram: Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNELS=DawnNews,GeoNews,AlJazeera,Reuters,APNews

# ── Facebook/Meta (NEW - for Facebook Page upload) ─────────────────────────
# Facebook Page ID: Go to your Page → Settings → Page Info → Page ID
FACEBOOK_PAGE_ID=

# Facebook Page Access Token: 
# 1. Go to https://developers.facebook.com/apps
# 2. Create app or select existing
# 3. Add "Pages" product
# 4. Get token with permissions: pages_manage_posts, pages_read_engagement, publish_video
# 5. Token should be long-lived (60 days)
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram Account ID (for cross-posting Reels)
# Go to Instagram Settings → Account → Switch to Professional Account
# Then get ID from Facebook Graph API
INSTAGRAM_ACCOUNT_ID=

# ── Database ─────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=automedia_ai

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Settings ─────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
OUTPUT_DIR=./output
TEMP_DIR=./temp

# ── Content Settings ─────────────────────────────
MIN_SOURCES_TO_VALIDATE=3
MAX_TOPICS_PER_RUN=8
TARGET_VIDEO_DURATION=300
CONTENT_LANGUAGE=en
TRENDING_REGION=US
VIDEO_FORMAT=shorts
VIDEO_RESOLUTION=1080p
SCRIPT_LANGUAGE=auto
CONTENT_PERSPECTIVE=balanced
BLOCKED_TOPICS=
TTS_VOLUME_BOOST=2.0
FOCUS_KEYWORDS=IranvsIsrail war,Imran khan condition,Iran War update,IRAN VS USA,IRAN VS ISRAIL,PAKISTAN & UAE
CONTENT_NICHE=current_affairs
